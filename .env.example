# ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Web Push / PWA ───
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@yoursite.com

# ─── App ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=BoostPlatform

# ─── Stripe ───
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── PayPal ───
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# ─── Discord (OAuth in webapp) ───
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ─── Email (Resend) ───
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# ─── Encryption ───
# NEVER commit .env to git. Keep these keys secure and private.
CREDENTIALS_ENCRYPTION_KEY=
SETTINGS_ENCRYPTION_KEY=
# 64 hex chars (32 bytes) — used for AES-256-GCM encryption of worker payout details
PAYOUT_ENCRYPTION_KEY=

# ─── Admin import ───
# Secret for the OSRS item import endpoint (Authorization: Bearer <secret>)
IMPORT_SECRET=

# ─── Cron (Vercel cron jobs) ───
CRON_SECRET=

# ─── Rate limiting (Upstash Redis, optional) ───
# Required for production: shared rate limits across serverless instances.
# Get credentials from https://console.upstash.com
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
