DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Base URL of your BoostPlatform site (for order links in embeds)
SITE_URL=

# ── Channels (configure via /admin/discord in the webapp) ──────────────────
# Admin channel — new orders notification
DISCORD_CHANNEL_NEW_ORDERS=

# Channel for completed order notifications
DISCORD_CHANNEL_COMPLETED_ORDERS=

# Worker channel — available orders posted here with Claim button
DISCORD_CHANNEL_WORKER_NOTIFICATIONS=

# Admin alerts (claimed, assigned, etc.)
DISCORD_CHANNEL_ADMIN_ALERTS=

# Reviews channel — new customer reviews posted here
DISCORD_CHANNEL_REVIEWS=

# Category ID for private order ticket channels
# Create a category in your Discord server (e.g. "Order Tickets") and paste its ID here
DISCORD_CATEGORY_TICKETS=

# ── Roles ──────────────────────────────────────────────────────────────────
DISCORD_ROLE_CUSTOMER=
DISCORD_ROLE_WORKER=
DISCORD_ROLE_ADMIN=
